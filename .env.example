# Client-side variables. These two are the ONLY VITE_-prefixed vars this project will
# ever have — anything prefixed VITE_ ends up in the public bundle. Server-side secrets
# (bank keys, service role key, webhook tokens) live in Supabase Edge Function secrets,
# never here.

# Supabase project URL — Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=

# Supabase anon (public) key — Dashboard → Project Settings → API → anon public.
# Safe to expose: row-level security is what enforces access, not this key.
VITE_SUPABASE_ANON_KEY=
